// prisma/schema.prisma

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum JobStatus {
    PROCESSING
    OFFERED
    ACCEPTED
    REJECTED
    WITHDRAWN
}

enum JobType {
    FULL_TIME
    PART_TIME
    CONTRACT
    INTERNSHIP
    REMOTE
    HYBRID
}

model User {
    id       String @id @default(cuid())
    name     String
    email    String @unique
    password String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    jobs JobApplication[]

    accounts Account[]
    sessions Session[]
}

model JobApplication {
    id String @id @default(cuid())

    companyName String
    jobPosition String

    status  JobStatus @default(PROCESSING)
    jobType JobType?

    description String? @db.Text

    location String?
    salary   String?

    jobPostingUrl String?

    personalNotes String? @db.Text

    referrerName        String?
    referrerProfileLink String?

    fileName String?
    fileUrl  String?
    fileType String?
    fileSize Int?

    interviewCount Int @default(0)

    nextInterviewDate DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([status])
    // Dashboard queries
    @@index([userId, status])
    // Sorting
    @@index([createdAt])
    @@index([nextInterviewDate])
    // Search
    @@index([companyName])
    @@index([companyName, jobPosition])
}

model Account {
    id String @id @default(cuid())

    userId String

    type              String
    provider          String
    providerAccountId String

    refresh_token String? @db.Text
    access_token  String? @db.Text

    expires_at Int?

    token_type String?
    scope      String?

    id_token      String? @db.Text
    session_state String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id String @id @default(cuid())

    sessionToken String @unique

    userId String

    expires DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model VerificationToken {
    identifier String

    token String @unique

    expires DateTime

    @@unique([identifier, token])
}
